{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "admin-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/admin-web/assets/$1"
    },
    {
      "src": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico|css|js)",
      "dest": "/admin-web/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/admin-web/index.html"
    }
  ],
  "env": {
    "DB_SSL": "true"
  }
}
